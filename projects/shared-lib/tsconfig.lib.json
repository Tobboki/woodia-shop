/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/lib",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": []
  },
  "paths": {
    "@components/*": [
      "src/lib/components/*"
    ],
    "@directives/*": [
      "src/lib/directives/*"
    ],
    "@utils/*": [
      "src/lib/utils/*"
    ],
    "@models/*": [
      "src/lib/furniture/models/*"
    ]
  },
  "include": [
    "src/**/*.ts",
    "../woodia/src/app/shared/types/chat.types.ts",
    "../woodia/src/app/core/services/chat.service.spec.ts",
    "../woodia/src/app/core/services/chat.service.ts",
    "../woodia/src/app/core/services/chathub.service.spec.ts",
    "../woodia/src/app/core/services/chathub.service.ts"
  ],
  "exclude": [
    "**/*.spec.ts"
  ]
}